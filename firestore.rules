rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: /users/{uid}
    // Fields: uid, businessName, logoUrl, phone, whatsapp, address, currency, invoicePrefix, language, theme
    //
    // Collection: /customers
    // Fields: id, ownerUid, name, phone, whatsapp, address, notes, isVip, totalOrders, unpaidBalance, lastOrderDate, favoriteItems
    //
    // Collection: /orders
    // Fields: id, orderNumber, ownerUid, customerId, customerName, date, items[], subtotal, discount, deliveryCharges, tax, total, advancePaid, balance, paymentMethod, paymentStatus, deliveryStatus, notes
    //
    // Collection: /offers
    // Fields: id, ownerUid, title, description, discountCode, imageUrl, expiryDate
    //
    // Collection: /notifications
    // Fields: id, ownerUid, title, message, date, isRead, type
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.ownerUid;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "gbbhi6914@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isUnchanged(field) {
      return !(field in request.resource.data) || request.resource.data[field] == resource.data[field];
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return hasRequiredFields(['uid', 'businessName']) &&
             data.uid == request.auth.uid &&
             data.businessName is string && data.businessName.size() > 0 && data.businessName.size() < 100 &&
             (!('phone' in data) || (data.phone is string && data.phone.size() < 20)) &&
             (!('whatsapp' in data) || (data.whatsapp is string && data.whatsapp.size() < 20)) &&
             (!('address' in data) || (data.address is string && data.address.size() < 200));
    }

    function isValidCustomer(data) {
      return hasRequiredFields(['ownerUid', 'name', 'phone']) &&
             data.ownerUid == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.phone is string && data.phone.size() > 0 && data.phone.size() < 20 &&
             (!('address' in data) || (data.address is string && data.address.size() < 200)) &&
             (!('notes' in data) || (data.notes is string && data.notes.size() < 500));
    }

    function isValidOrder(data) {
      return hasRequiredFields(['ownerUid', 'customerId', 'orderNumber', 'total']) &&
             data.ownerUid == request.auth.uid &&
             data.orderNumber is string && data.orderNumber.size() < 50 &&
             data.total is number && data.total >= 0 &&
             (!('notes' in data) || (data.notes is string && data.notes.size() < 500));
    }

    function isValidOffer(data) {
      return hasRequiredFields(['ownerUid', 'title']) &&
             data.ownerUid == request.auth.uid &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             (!('description' in data) || (data.description is string && data.description.size() < 500));
    }

    function isValidNotification(data) {
      return hasRequiredFields(['ownerUid', 'title', 'message', 'date', 'isRead', 'type']) &&
             data.ownerUid == request.auth.uid &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.message is string && data.message.size() > 0 && data.message.size() < 500 &&
             data.isRead is bool &&
             data.type in ['order', 'payment', 'system'];
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && isValidUser(request.resource.data);
      allow update: if isOwner(uid) && isValidUser(request.resource.data);
    }

    match /customers/{customerId} {
      allow get: if isAuthenticated() && (resource == null || resource.data.ownerUid == request.auth.uid);
      allow list: if isAuthenticated() && (resource == null || resource.data.ownerUid == request.auth.uid);
      allow create: if isAuthenticated() && isValidCustomer(request.resource.data);
      allow update: if isDocOwner() && isValidCustomer(request.resource.data) && isUnchanged('ownerUid');
      allow delete: if isDocOwner();
    }

    match /orders/{orderId} {
      allow get: if isAuthenticated() && (resource == null || resource.data.ownerUid == request.auth.uid);
      allow list: if isAuthenticated() && (resource == null || resource.data.ownerUid == request.auth.uid);
      allow create: if isAuthenticated() && isValidOrder(request.resource.data);
      allow update: if isDocOwner() && isValidOrder(request.resource.data) && isUnchanged('ownerUid');
      allow delete: if isDocOwner();
    }

    match /offers/{offerId} {
      allow get: if isAuthenticated() && (resource == null || resource.data.ownerUid == request.auth.uid);
      allow list: if isAuthenticated() && (resource == null || resource.data.ownerUid == request.auth.uid);
      allow create: if isAuthenticated() && isValidOffer(request.resource.data);
      allow update: if isDocOwner() && isValidOffer(request.resource.data) && isUnchanged('ownerUid');
      allow delete: if isDocOwner();
    }

    match /notifications/{notificationId} {
      allow get: if isAuthenticated() && (resource == null || resource.data.ownerUid == request.auth.uid);
      allow list: if isAuthenticated() && (resource == null || resource.data.ownerUid == request.auth.uid);
      allow create: if isAuthenticated() && isValidNotification(request.resource.data);
      allow update: if isDocOwner() && isValidNotification(request.resource.data) && isUnchanged('ownerUid');
      allow delete: if isDocOwner();
    }
  }
}
